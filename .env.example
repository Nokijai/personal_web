# Application
NEXT_PUBLIC_SITE_URL=https://worldofnoki.com

# GitHub (optional - for dynamic repo fetching)
GITHUB_TOKEN=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=

# ── LLM Chat API ───────────────────────────────────────────
# Provider: "openai" | "anthropic"  (default: openai)
LLM_PROVIDER=openai

# API key for the chosen provider (required)
LLM_API_KEY=

# Model override (defaults: openai→gpt-4o-mini, anthropic→claude-sonnet-4-20250514)
# LLM_MODEL=gpt-4o-mini

# Optional tuning
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=2048

# Optional base URL overrides (for proxies, Azure, local vLLM, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
